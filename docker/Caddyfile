{
	auto_https off
	admin off
	frankenphp
}

:{$PORT:8080} {
	root * /app/public
	encode zstd gzip

	# PWA: never cache the service worker as an immutable asset.
	@serviceWorker path /service-worker.js
	header @serviceWorker Cache-Control "no-cache"
	header @serviceWorker Service-Worker-Allowed "/"
	header @serviceWorker Content-Type "application/javascript; charset=UTF-8"

	@webmanifest path /manifest.webmanifest
	header @webmanifest Cache-Control "no-cache"
	header @webmanifest Content-Type "application/manifest+json"

	@offline path /offline.html
	header @offline Cache-Control "no-cache"

	# Hashed Vite / Filament assets may be cached aggressively.
	@immutableAssets path /build/* /js/filament/* /css/filament/* /fonts/filament/*
	header @immutableAssets Cache-Control "public, max-age=31536000, immutable"

	php_server
}
