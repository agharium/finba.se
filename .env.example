APP_NAME=Finba
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=filament_finba
DB_USERNAME=root
DB_PASSWORD=
# Supabase / production usually requires SSL:
# DB_SSLMODE=require
# Prefer the transaction pooler host for Cloud Run (document in docs/deployment-gcp-cloud-run.md).

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production (HTTPS):
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Local: database (+ `php artisan queue:listen` via composer dev).
# Cloud Run beta: sync (no worker service deployed).
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Production (Resend):
# MAIL_MAILER=resend
# RESEND_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Absolute URL in production, e.g. https://app.finba.se/auth/google/callback
GOOGLE_REDIRECT_URL=/auth/google/callback

APP_VERSION=0.1.0-beta
APP_STAGE=Beta
APP_BUILD=local
GIT_SHA=

FINBA_STORAGE_DISK=local

SUPABASE_STORAGE_ACCESS_KEY_ID=
SUPABASE_STORAGE_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_REGION=
SUPABASE_STORAGE_BUCKET=
SUPABASE_STORAGE_ENDPOINT=

FINBA_FEEDBACK_EMAIL=
FINBA_FEEDBACK_RATE_LIMIT=8
FINBA_FEEDBACK_MAX_ATTACHMENT_KB=2048

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Production / Cloud Run non-secret reminders (do not commit real .env)
# -----------------------------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://app.finba.se
# LOG_CHANNEL=stderr
# LOG_LEVEL=info
# FINBA_STORAGE_DISK=finba
# QUEUE_CONNECTION=sync
# SESSION_DRIVER=database
# CACHE_STORE=database
# APP_VERSION=0.1.0-beta
# APP_STAGE=Beta